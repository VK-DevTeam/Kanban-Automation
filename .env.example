# Asana Configuration
ASANA_ACCESS_TOKEN=example_token
ASANA_PROJECT_GID=example_token
ASANA_TRIGGER_SECTION_NAME=VK-Allocate Rjob
ASANA_WEBHOOK_SECRET=example_token

# Trello Configuration
TRELLO_API_KEY=example_token
TRELLO_TOKEN=example_token
TRELLO_TARGET_LIST_ID=example_token

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=5

# Timeout Configuration (seconds)
API_TIMEOUT_SECONDS=30
ATTACHMENT_TIMEOUT_SECONDS=300

# Alerting
DLQ_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Logging
LOG_LEVEL=INFO

